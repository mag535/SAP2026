  - type: 2
    Guid: da58b397-3dba-42aa-9cfd-9a940681d101
    speaker: Fox
    DialogueText: '"Oh, you saw the poster in the bar? It has the <color="yellow">four
      auspicious beasts and its corresponding direction.</color>" '
    cost: {fileID: 0}
    trade: {fileID: 11400000, guid: f78f1f7a48c88c4458b5dbfba4215e75, type: 2}
    flag: 
    Position: {x: 235.2, y: 160}
  - type: 0
    Guid: dc2a34c9-da1f-4e7f-9d9b-1927a9f333ce
    speaker: Fox
    DialogueText: '"You see how the bar on the west side has the White Tiger, and
      the temple in the east has an Azure Dragon? Think you could rub those two braincells
      together to figure out what animal would be in the palace north?"'
    cost: {fileID: 0}
